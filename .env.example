# Local dev environment for docker-compose.yml (and, later, the backend).
# Copy to `.env` and adjust as needed: `cp .env.example .env`.
# `.env` is git-ignored; this example file is tracked.

# PostgreSQL (consumed by docker-compose.yml)
POSTGRES_DB=expense-tracker
POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
POSTGRES_PORT=5432

# Backend datasource (consumed by backend/src/main/resources/application.yml).
# Defaults match the compose service above; override when pointing at another DB.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=expense-tracker
DB_USER=expense
DB_PASSWORD=expense
# SERVER_PORT=8080

