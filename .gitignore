# ─── Backend (Java / Maven / Spring Boot) ───────────────────────────────
# Build output only — do NOT blanket-ignore *.jar/*.war: the committed Maven
# wrapper jar (.mvn/wrapper/maven-wrapper.jar) must stay tracked so ./mvnw works
# on fresh clones and in CI.
backend/target/
backend/build/
*.class
hs_err_pid*

# ─── Frontend (Node / Vite / React) ─────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/.vite/
*.local

# ─── Logs ───────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment / secrets ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── IDE / editor ───────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
.DS_Store

# ─── Test / build artifacts ─────────────────────────────────────────────
*.tsbuildinfo
